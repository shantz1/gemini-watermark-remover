{
  "name": "@pilio/gemini-watermark-remover",
  "description": "Automatically removes watermarks from Gemini AI generated images",
  "version": "1.0.15",
  "author": "GargantuaX",
  "sideEffects": false,
  "files": [
    "bin/",
    "skills/",
    "src/cli/",
    "src/core/",
    "src/runtime/",
    "src/sdk/",
    "src/shared/",
    "src/userscript/",
    "README.md",
    "README_zh.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GargantuaX/gemini-watermark-remover.git"
  },
  "homepage": "https://geminiwatermarkremover.io/",
  "license": "MIT",
  "type": "module",
  "bin": {
    "gwr": "./bin/gwr.mjs"
  },
  "types": "./src/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/sdk/index.d.ts",
      "import": "./src/sdk/index.js"
    },
    "./browser": {
      "types": "./src/sdk/browser.d.ts",
      "import": "./src/sdk/browser.js"
    },
    "./image-data": {
      "types": "./src/sdk/image-data.d.ts",
      "import": "./src/sdk/image-data.js"
    },
    "./node": {
      "types": "./src/sdk/node.d.ts",
      "import": "./src/sdk/node.js"
    },
    "./runtime-browser": {
      "types": "./src/runtime/browser.d.ts",
      "import": "./src/runtime/browser.js"
    },
    "./runtime-userscript": {
      "types": "./src/runtime/userscript.d.ts",
      "import": "./src/runtime/userscript.js"
    }
  },
  "scripts": {
    "dev": "node build.js",
    "build": "node build.js --prod",
    "clean": "node scripts/clean.js",
    "clean:all": "node scripts/clean.js --include-profile",
    "convert:samples:webp": "node scripts/convert-samples-to-webp.js",
    "test": "node --test tests/**/*.test.js",
    "test:sdk-smoke": "node --test tests/sdk/packageMetadata.test.js tests/sdk/packagePack.test.js tests/sdk/typeDeclarations.test.js tests/sdk/consumerRuntime.test.js tests/sdk/typescriptConsumer.test.js tests/sdk/smokeAutomation.test.js",
    "probe:tm": "node scripts/tampermonkey-smoke.js run",
    "probe:tm:freshness": "node scripts/tampermonkey-freshness.js",
    "probe:tm:profile": "node scripts/open-tampermonkey-profile.js",
    "probe:tm:setup": "node scripts/tampermonkey-smoke.js setup",
    "probe:real-page:compare": "node scripts/real-page-pixel-compare.js",
    "benchmark:samples": "node scripts/sample-benchmark.js",
    "benchmark:userscript": "node scripts/userscript-benchmark.js",
    "package:extension": "node scripts/package-extension-release.js",
    "cli:smoke": "node bin/gwr.mjs --help",
    "serve": "pnpm dlx serve dist",
    "export:samples": "node scripts/export-fixed-samples.js",
    "calibrate:preview-alpha": "node scripts/calibrate-preview-alpha.js"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "esbuild": "^0.24.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
